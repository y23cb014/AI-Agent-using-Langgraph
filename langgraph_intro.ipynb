   "source": [
    "from typing import TypedDict\n",
    "\n",
    "# Define the schema for your graph's memory\n",
    "class MyState(TypedDict):\n",
    "    input: str\n",
    "    output: str\n",
    "\n",
    "# Now you can define your functions\n",
    "def function1(state: MyState):\n",
    "    llm = ChatGroq(groq_api_key=\"os.environ.get("GROQ_API_KEY")\", model=\"llama-3.1-8b-instant\")\n",
    "    response = llm.invoke(state[\"input\"]).content\n",
    "    return {\"output\": response}\n",
    "\n",
    "def function2(state: MyState):\n",
    "    upper_string = state[\"output\"].upper()\n",
    "    return {\"output\": upper_string}\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 18,
   "id": "82ed63c1",
   "metadata": {},
   "outputs": [],
   "source": [
    "from langgraph.graph import StateGraph, START, END\n",
    "\n",
    "# 1. Initialize the workflow with your state schema\n",
    "workflow = StateGraph(MyState)\n",
    "\n",
    "# 2. Add your nodes (using the functions you just defined)\n",
    "workflow.add_node(\"agent\", function1)\n",
    "workflow.add_node(\"processor\", function2)\n",
    "\n",
    "# 3. Define the flow\n",
    "workflow.add_edge(START, \"agent\")\n",
    "workflow.add_edge(\"agent\", \"processor\")\n",
    "workflow.add_edge(\"processor\", END)\n",
    "\n",
    "# 4. Compile it into an executable app\n",
    "app = workflow.compile()\n"
   ]
  },
